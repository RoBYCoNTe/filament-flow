{
    "name": "robyconte/filament-flow",
    "description": "A powerful Business Process Manager for Filament to handle model state transitions and workflows",
    "keywords": [
        "filament",
        "laravel",
        "workflow",
        "state-machine",
        "bpm",
        "business-process"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Roberto Conte Rosito",
            "email": "roberto.conterosito@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.0|^12.0",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-model-states": "^2.12"
    },
    "require-dev": {
        "larastan/larastan": "^2.11|^3.0",
        "laravel/pint": "^1.24",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0",
        "phpstan/phpstan": "^1.12|^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "RoBYCoNTe\\FilamentFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RoBYCoNTe\\FilamentFlow\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint --test",
        "lint:fix": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse",
        "check": [
            "@lint",
            "@phpstan"
        ],
        "check:all": [
            "@lint",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "RoBYCoNTe\\FilamentFlow\\FilamentFlowServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
